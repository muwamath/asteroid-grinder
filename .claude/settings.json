{
  "permissions": {
    "deny": [
      "Edit(dist/**)",
      "Write(dist/**)",
      "Edit(node_modules/**)",
      "Write(node_modules/**)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/typecheck-on-ts-edit.sh"
          }
        ]
      }
    ]
  }
}
